import { sql } from "@/lib/db";
import CitySelect from "./CitySelect";
import Link from "next/link";

export const dynamic = "force-dynamic";

export default async function Home({ searchParams }) {
  const params = await searchParams;
  const selectedCity = params?.city ?? "";
  const selectedAirport = params?.airport ?? "";

  const cities = await sql`
    SELECT DISTINCT airport_city
    FROM airport_master
    WHERE airport_country_code = 'GBR'
    ORDER BY airport_city
  `;

  let airportsInCity = [];
  if (selectedCity) {
    airportsInCity = await sql`
      SELECT iata_code, airport_name
      FROM airport_master
      WHERE airport_city = ${selectedCity}
        AND airport_country_code = 'GBR'
      ORDER BY airport_name
    `;
  }

  let activeAirport = null;
  if (selectedAirport) {
    activeAirport = airportsInCity.find((a) => a.iata_code === selectedAirport) ?? null;
  } else if (airportsInCity.length === 1) {
    activeAirport = airportsInCity[0];
  }

  let airlines = [];
  if (activeAirport) {
    airlines = await sql`
      SELECT DISTINCT al.iata_code, al.airline_name
      FROM routes r
      JOIN airline_master al ON r.airline_id = al.id
      WHERE r.source_iata = ${activeAirport.iata_code}
      ORDER BY al.airline_name
    `;
  }

  const showAirportColumn = selectedCity && airportsInCity.length > 1;

  return (
    <div className="page">
      <header className="page-header">
        <h1>Airlines from UK airports</h1>
        <p>Find which airlines fly from any UK airport.</p>
      </header>

      <section className="selectors">
        <div>
          <div className="column-label">City</div>
          <CitySelect cities={cities} selectedCity={selectedCity}/>
                  {showAirportColumn && (
              <div className="column-label">Airport
              <ul className="airport-list">
                {airportsInCity.map((a) => {
                  const isSelected = activeAirport?.iata_code === a.iata_code;
                  return (
                    <li key={a.iata_code}>
                      <Link 
                        className={`airport-item${isSelected ? " selected" : ""}`}
                        href={`?city=${encodeURIComponent(selectedCity)}&airport=${a.iata_code}`}>
                        {a.airport_name}
                        <span className="airport-iata">{a.iata_code}</span>
                      </Link>
                    </li>
                  );
                })}
              </ul>
              </div>          )}
        </div>

        <div>
          {activeAirport ? (
            <div className="airlines-panel">
              <h2>
                Airlines from {activeAirport.airport_name}
                <span className="count">{airlines.length} carriers</span>
              </h2>
              {airlines.length === 0 ? (
                <p className="empty-state">No airlines found for this airport.</p>
              ) : (
                <ul className="airlines-list">
                  {airlines.map((a) => (
                    <li key={a.iata_code}>
                      <Link href="">
                        {a.airline_name}
                      </Link>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ) : (
            <div className="airlines-panel">
              <p className="empty-state">
                {selectedCity
                  ? "Select an airport to see its airlines."
                  : "Select a city to begin."}
              </p>
            </div>
          )}
        </div>
      </section>

      <footer className="page-footer">
        Data from{" "}
        <a href="https://github.com/Jonty/airline-route-data">
          Jonty/airline-route-data
        </a>
        .
      </footer>
    </div>
  );
}